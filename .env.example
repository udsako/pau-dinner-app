# Database — get a free PostgreSQL URL from https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Secret — generate a random 64-char string
JWT_SECRET="replace-with-a-long-random-secret-string"

# App URL (for QR codes)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret — used to protect the grace timer cron endpoint
CRON_SECRET="replace-with-another-random-secret"
